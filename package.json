{
  "name": "gueclaw-agent",
  "version": "2.0.0",
  "description": "GueClaw - Personal AI Agent for VPS with Telegram Interface",
  "main": "dist/index.js",
  "scripts": {
    "dev": "nodemon --exec ts-node src/index.ts",
    "build": "tsc",
    "start": "node dist/index.js",
    "lint": "eslint src --ext .ts",
    "lint:fix": "eslint src --ext .ts --fix",
    "test": "jest",
    "test:unit": "jest --testPathPattern=unit",
    "test:e2e": "jest --testPathPattern=e2e",
    "test:watch": "jest --watch",
    "test:copilot": "ts-node scripts/test-copilot.ts",
    "copilot:auth": "ts-node scripts/auth-copilot.ts",
    "validate": "npm run lint:fix && npm run build && npm run test:unit",
    "secrets:scan": "node scripts/check-secrets.js",
    "debug:simulate": "node scripts/debug-api.js simulate",
    "debug:logs": "node scripts/debug-api.js logs",
    "debug:tunnel": "node scripts/debug-api.js tunnel",
    "debug:stats": "node scripts/debug-api.js stats",
    "debug:conversations": "node scripts/debug-api.js conversations"
  },
  "keywords": [
    "ai-agent",
    "telegram-bot",
    "vps-automation",
    "docker-control"
  ],
  "author": "Sandeco",
  "license": "MIT",
  "dependencies": {
    "@grammyjs/files": "^1.1.0",
    "@modelcontextprotocol/sdk": "^1.27.1",
    "@types/express": "^5.0.6",
    "axios": "^1.6.7",
    "better-sqlite3": "^9.6.0",
    "csv-parse": "^5.5.3",
    "dotenv": "^16.4.5",
    "express": "^5.2.1",
    "grammy": "^1.20.3",
    "js-yaml": "^4.1.0",
    "papaparse": "^5.4.1",
    "pdf-parse": "^1.1.1",
    "sharp": "^0.33.2",
    "uuid": "^13.0.0",
    "winston": "^3.11.0",
    "zod": "^3.22.4"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.9",
    "@types/jest": "^29.5.14",
    "@types/js-yaml": "^4.0.9",
    "@types/node": "^20.11.19",
    "@types/papaparse": "^5.3.14",
    "@types/pdf-parse": "^1.1.4",
    "@types/supertest": "^7.2.0",
    "@types/uuid": "^10.0.0",
    "@typescript-eslint/eslint-plugin": "^8.57.0",
    "@typescript-eslint/parser": "^8.57.0",
    "eslint": "^8.56.0",
    "jest": "^29.7.0",
    "nodemon": "^3.0.3",
    "supertest": "^7.2.2",
    "ts-jest": "^29.4.6",
    "ts-node": "^10.9.2",
    "typescript": "^5.3.3"
  },
  "engines": {
    "node": ">=20.0.0"
  }
}
