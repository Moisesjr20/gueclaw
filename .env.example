# ============================================
# GueClaw Agent v2.2.0 — EXAMPLE CONFIGURATION
# Copie este arquivo para .env e preencha com seus valores reais
# NÃO commite o arquivo .env no repositório
# ============================================

# ===== Telegram =====
TELEGRAM_BOT_TOKEN=your_telegram_bot_token
TELEGRAM_ALLOWED_USER_IDS=your_telegram_user_id

# ===== OpenRouter (Principal — acesso a 200+ modelos) =====
OPENROUTER_API_KEY=your_openrouter_api_key
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
OPENROUTER_MODEL=deepseek/deepseek-r1
OPENROUTER_APP_NAME=GueClaw-Agent

# ===== CoT Routing — 7 Modelos Especialistas =====
# DeepSeek R1 classifica cada mensagem e roteia para o modelo certo
ROUTER_COT_ENABLED=false                          # true em produção
ROUTER_TRIAGE_MODEL=deepseek/deepseek-r1

# Modelos por categoria (override dos padrões)
ROUTER_MODEL_REASONING=deepseek/deepseek-r1       # matemática, lógica, análise
ROUTER_MODEL_AGENTIC=moonshotai/kimi-k2           # docker, shell, automação
ROUTER_MODEL_TEXT=qwen/qwen3-235b-a22b            # redação, emails, relatórios
ROUTER_MODEL_FAST=google/gemma-3-27b-it           # saudações, respostas rápidas
ROUTER_MODEL_LONGOUTPUT=thudm/glm-z1-32b          # documentos e código longos
ROUTER_MODEL_CODE=deepseek/deepseek-r1            # TypeScript, Python, debugging
ROUTER_MODEL_FALLBACK=deepseek/deepseek-chat-v3-0324

# ===== RAG Profundo (PostgreSQL + pgvector) =====
# Suba o banco: docker compose -f deploy/postgres-rag/docker-compose.yml up -d
RAG_POSTGRES_URL=postgresql://gueclaw:changeme@localhost:5433/gueclaw_rag
RAG_DOCUMENTS_DIR=./data/documents
RAG_EMBEDDING_MODEL=openai/text-embedding-3-small
RAG_CHUNK_SIZE=500
RAG_CHUNK_OVERLAP=50
RAG_TOP_K=5

# ===== Providers Alternativos =====

# DeepSeek (direto)
DEEPSEEK_API_KEY=your_deepseek_api_key
DEEPSEEK_BASE_URL=https://api.deepseek.com/v1
DEEPSEEK_MODEL_FAST=deepseek-chat
DEEPSEEK_MODEL_REASONING=deepseek-reasoner

# Anthropic Claude (direto)
ANTHROPIC_API_KEY=your_anthropic_api_key
ANTHROPIC_MODEL=claude-sonnet-4-6
ANTHROPIC_BASE_URL=https://api.anthropic.com

# Google Gemini
GEMINI_API_KEY=your_gemini_api_key
GEMINI_MODEL=gemini-2.0-flash

# OpenAI (direto)
OPENAI_API_KEY=your_openai_api_key
OPENAI_MODEL=gpt-4o
OPENAI_BASE_URL=https://api.openai.com/v1

# GitHub Copilot (OAuth)
GITHUB_COPILOT_USE_OAUTH=false
GITHUB_COPILOT_MODEL=claude-sonnet-4.5

# ===== Agent =====
MAX_ITERATIONS=30
MEMORY_WINDOW_SIZE=60
DEFAULT_PROVIDER=openrouter

# ===== VPS =====
VPS_HOST=your_vps_ip
VPS_PORT=22
VPS_USER=root
VPS_SSH_KEY_PATH=~/.ssh/your_ssh_key

# ===== Docker =====
DOCKER_HOST=unix:///var/run/docker.sock
DOCKER_NETWORK=gueclaw-network

# ===== Database (SQLite — memória do agente) =====
DATABASE_PATH=./data/gueclaw.db
ENABLE_WAL=true

# ===== File Processing =====
MAX_FILE_SIZE_MB=50
TEMP_DIR=./tmp
ALLOWED_AUDIO_FORMATS=mp3,ogg,wav,m4a
ALLOWED_DOCUMENT_FORMATS=pdf,csv,txt,md,json

# ===== Logging =====
LOG_LEVEL=info
LOG_FILE=./logs/gueclaw.log
DEBUG_ROUTING=false

# ===== Cost Tracker =====
COST_ALERT_DAILY_USD=20.0
COST_ALERT_WEEKLY_USD=30.0
COST_ALERT_MONTHLY_USD=100.0
COST_ALERTS_ENABLED=true

# ===== Security =====
ENABLE_RATE_LIMITING=true
MAX_REQUESTS_PER_MINUTE=30
FILE_WORKSPACE_ROOT=/opt/gueclaw-agent

# ===== Context Compression =====
CONTEXT_COMPACT_THRESHOLD=30
CONTEXT_RECENT_WINDOW=10
CONTEXT_INITIAL_KEEP=2
CONTEXT_COMPRESSION_STRATEGY=sliding-window

# ===== Memory Extraction =====
MEMORY_EXTRACT_ENABLED=true
MEMORY_EXTRACT_MIN_MESSAGES=15
MEMORY_EXTRACT_MAX_BATCH=20
MEMORY_EXTRACT_MIN_CONFIDENCE=0.7

# ===== Feature Flags =====
ENABLE_FORKED_SKILLS=false
