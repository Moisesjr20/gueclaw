# ============================================
# GueClaw Agent Configuration
# ============================================

# ===== Telegram Configuration =====
TELEGRAM_BOT_TOKEN=your_bot_token_here
TELEGRAM_ALLOWED_USER_IDS=123456789,987654321

# ===== LLM Providers Configuration =====
# GitHub Copilot (Primary - Recommended)
# Option 1: OAuth (requires Copilot Pro subscription)
GITHUB_COPILOT_USE_OAUTH=true
GITHUB_COPILOT_MODEL=claude-sonnet-4.5

# Option 2: API Key (fallback)
GITHUB_COPILOT_API_KEY=your_github_copilot_api_key
GITHUB_COPILOT_BASE_URL=https://api.openai.com/v1
GITHUB_COPILOT_MODEL=gpt-4o
GITHUB_COPILOT_API_TYPE=openai

# DeepSeek (Fast and cheap)
DEEPSEEK_API_KEY=your_deepseek_api_key
DEEPSEEK_BASE_URL=https://api.deepseek.com/v1
DEEPSEEK_MODEL_FAST=deepseek-chat
DEEPSEEK_MODEL_REASONING=deepseek-reasoner

# OpenRouter (200+ models, pay-as-you-go)
OPENROUTER_API_KEY=your_openrouter_api_key
OPENROUTER_MODEL=anthropic/claude-sonnet-4.5
OPENROUTER_APP_NAME=GueClaw-Agent

# Anthropic Claude (Direct)
ANTHROPIC_API_KEY=your_anthropic_api_key
ANTHROPIC_MODEL=claude-sonnet-4-6
ANTHROPIC_BASE_URL=https://api.anthropic.com

# Google Gemini
GEMINI_API_KEY=your_gemini_api_key
GEMINI_MODEL=gemini-3-pro-preview

# OpenAI (Direct)
OPENAI_API_KEY=your_openai_api_key
OPENAI_MODEL=gpt-5.4
OPENAI_BASE_URL=https://api.openai.com/v1

# ===== Smart Model Routing =====
# Automatically choose cheap model for simple tasks, powerful model for complex
SMART_ROUTING_ENABLED=true
SMART_ROUTING_CHEAP_PROVIDER=deepseek
SMART_ROUTING_CHEAP_MODEL=deepseek-chat
SMART_ROUTING_MAX_CHARS=160    # Max chars for simple task
SMART_ROUTING_MAX_WORDS=28     # Max words for simple task
DEBUG_ROUTING=false             # Log routing decisions

# ===== Agent Configuration =====
MAX_ITERATIONS=5
MEMORY_WINDOW_SIZE=10
DEFAULT_PROVIDER=deepseek

# ===== VPS Configuration =====
VPS_HOST=your_vps_ip_or_hostname
VPS_PORT=22
VPS_USER=root
VPS_PASSWORD=your_vps_password_optional
VPS_SSH_KEY_PATH=/path/to/ssh/private/key
VPS_SUDO_PASSWORD=your_sudo_password_if_needed

# ===== Docker Configuration =====
DOCKER_HOST=unix:///var/run/docker.sock
DOCKER_NETWORK=gueclaw-network

# ===== Database Configuration =====
DATABASE_PATH=./data/gueclaw.db
ENABLE_WAL=true

# ===== File Processing =====
MAX_FILE_SIZE_MB=50
TEMP_DIR=./tmp
ALLOWED_AUDIO_FORMATS=mp3,ogg,wav,m4a
ALLOWED_DOCUMENT_FORMATS=pdf,csv,txt,md,json

# ===== Logging =====
LOG_LEVEL=info
LOG_FILE=./logs/gueclaw.log

# ===== Cost Tracker & Alerts (Phase 2.3) =====
# Alertas automáticos quando ultrapassar thresholds
COST_ALERT_DAILY_USD=5.0
COST_ALERT_WEEKLY_USD=30.0
COST_ALERT_MONTHLY_USD=100.0
COST_ALERTS_ENABLED=true

# ===== Security =====
ENABLE_RATE_LIMITING=true
MAX_REQUESTS_PER_MINUTE=30
# Restrict file operations to this directory (path traversal protection)
FILE_WORKSPACE_ROOT=/opt/gueclaw-agent

# ===== File Repository =====
# Directory where user-accessible files are stored (HTML, JSON, CSV, etc)
# Files saved with save_to_repository tool go here
FILES_REPOSITORY_PATH=/opt/gueclaw-data/files/workspace

# ===== Context Compression (Phase 3.1) =====
# Intelligent context compression - reduces tokens by 40%+ in long conversations
CONTEXT_COMPACT_THRESHOLD=30           # Trigger compression at 30 messages
CONTEXT_RECENT_WINDOW=10               # Keep last 10 messages uncompressed
CONTEXT_INITIAL_KEEP=2                 # Keep first 2 messages (grounding)
CONTEXT_COMPRESSION_STRATEGY=sliding-window  # Strategy: sliding-window | aggressive | preserve-first | none

# ===== Advanced Memory Extraction (Phase 3.2) =====
# Automatic extraction of preferences, decisions, facts, goals from conversations
MEMORY_EXTRACT_ENABLED=true            # Enable automatic memory extraction
MEMORY_EXTRACT_MIN_MESSAGES=10         # Minimum messages before extraction
MEMORY_EXTRACT_MAX_BATCH=20            # Max messages per extraction batch
MEMORY_EXTRACT_MIN_CONFIDENCE=0.7      # Minimum confidence to store (0-1)

# ===== Feature Flags =====
# Enable forked execution mode for skills (isolated context)
ENABLE_FORKED_SKILLS=false
