# ============================================
# GueClaw Agent Configuration — EXAMPLE FILE
# Copie este arquivo para .env e preencha com seus valores reais
# NÃO commite o arquivo .env no repositório
# ============================================

# ===== Telegram Configuration =====
TELEGRAM_BOT_TOKEN=your_telegram_bot_token
TELEGRAM_ALLOWED_USER_IDS=your_telegram_user_id

# ===== LLM Providers Configuration =====

# GitHub Copilot (Primary - Recommended)
GITHUB_COPILOT_USE_OAUTH=true
GITHUB_COPILOT_MODEL=claude-sonnet-4.5

# Ollama Cloud
OLLAMA_CLOUD_API_KEY=your_ollama_cloud_api_key
OLLAMA_CLOUD_BASE_URL=https://api.ollama.com/v1
OLLAMA_CLOUD_MODEL=deepseek-v4-flash
OLLAMA_CLOUD_MAX_TOKENS=4096
OLLAMA_CLOUD_TEMPERATURE=0.7

# DeepSeek (Fast and cheap)
DEEPSEEK_API_KEY=your_deepseek_api_key
DEEPSEEK_BASE_URL=https://api.deepseek.com/v1
DEEPSEEK_MODEL_FAST=deepseek-chat
DEEPSEEK_MODEL_REASONING=deepseek-reasoner

# OpenRouter (200+ models, pay-as-you-go)
OPENROUTER_API_KEY=your_openrouter_api_key
OPENROUTER_MODEL=qwen/qwen3.5-plus-20260420
OPENROUTER_APP_NAME=GueClaw-Agent

# Anthropic Claude (Direct)
ANTHROPIC_API_KEY=your_anthropic_api_key
ANTHROPIC_MODEL=claude-sonnet-4-6
ANTHROPIC_BASE_URL=https://api.anthropic.com

# Google Gemini
GEMINI_API_KEY=your_gemini_api_key
GEMINI_MODEL=gemini-3-pro-preview

# OpenAI (Direct)
OPENAI_API_KEY=your_openai_api_key
OPENAI_MODEL=gpt-4o
OPENAI_BASE_URL=https://api.openai.com/v1

# ===== Smart Model Routing =====
SMART_ROUTING_ENABLED=true
SMART_ROUTING_CHEAP_PROVIDER=deepseek
SMART_ROUTING_CHEAP_MODEL=deepseek-chat
SMART_ROUTING_MAX_CHARS=160
SMART_ROUTING_MAX_WORDS=28
DEBUG_ROUTING=false

# ===== Agent Configuration =====
MAX_ITERATIONS=30
MEMORY_WINDOW_SIZE=60
DEFAULT_PROVIDER=deepseek

# ===== VPS Configuration =====
VPS_HOST=your_vps_ip
VPS_PORT=22
VPS_USER=root
VPS_SSH_KEY_PATH=~/.ssh/your_ssh_key

# ===== Docker Configuration =====
DOCKER_HOST=unix:///var/run/docker.sock
DOCKER_NETWORK=gueclaw-network

# ===== Database Configuration =====
DATABASE_PATH=./data/gueclaw.db
ENABLE_WAL=true

# ===== File Processing =====
MAX_FILE_SIZE_MB=50
TEMP_DIR=./tmp
ALLOWED_AUDIO_FORMATS=mp3,ogg,wav,m4a
ALLOWED_DOCUMENT_FORMATS=pdf,csv,txt,md,json

# ===== Logging =====
LOG_LEVEL=info
LOG_FILE=./logs/gueclaw.log

# ===== Cost Tracker & Alerts =====
COST_ALERT_DAILY_USD=20.0
COST_ALERT_WEEKLY_USD=30.0
COST_ALERT_MONTHLY_USD=100.0
COST_ALERTS_ENABLED=true

# ===== Mayan EDMS (Document Governance) =====
MAYAN_API_URL=https://your_mayan_url/api
MAYAN_API_TOKEN=your_mayan_api_token
MAYAN_ADMIN_USER=admin
MAYAN_ADMIN_PASSWORD=your_mayan_password

# ===== Security =====
ENABLE_RATE_LIMITING=true
MAX_REQUESTS_PER_MINUTE=30
FILE_WORKSPACE_ROOT=/opt/gueclaw-agent

# ===== File Repository =====
FILES_REPOSITORY_PATH=/opt/gueclaw-data/files/workspace

# ===== Context Compression =====
CONTEXT_COMPACT_THRESHOLD=30
CONTEXT_RECENT_WINDOW=10
CONTEXT_INITIAL_KEEP=2
CONTEXT_COMPRESSION_STRATEGY=sliding-window

# ===== Advanced Memory Extraction =====
MEMORY_EXTRACT_ENABLED=true
MEMORY_EXTRACT_MIN_MESSAGES=15
MEMORY_EXTRACT_MAX_BATCH=20
MEMORY_EXTRACT_MIN_CONFIDENCE=0.7

# ===== Feature Flags =====
ENABLE_FORKED_SKILLS=false
