# URL base da debug-api na VPS (sem trailing slash)
# Produção: use o IP/domínio da sua VPS
GUECLAW_API_URL=http://your-vps-ip:3742

# Chave da API (configure no Vercel com o mesmo valor do .env do VPS)
# IMPORTANTE: Gere uma chave segura única para seu ambiente
GUECLAW_API_KEY=gc_dash_XXXXXXXX_XXXXXXXXXXXXXXXX

# Senha para proteger a aba de Controle Financeiro
# IMPORTANTE: No Vercel, configure uma senha forte!
NEXT_PUBLIC_FINANCIAL_PASSWORD=your_strong_password_here
