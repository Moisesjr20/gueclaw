# Dependencies
node_modules/
package-lock.json
yarn.lock

# Build outputs
dist/
build/

# Environment variables
.env
.env.local
.env.*.local

# Data and temporary files
data/*.db
data/*.sqlite
tmp/*
!tmp/.gitkeep
logs/*
!logs/.gitkeep

# MCP memory — pode conter dados sensíveis de sessões anteriores
data/memory/mcp-memory.jsonl

# Skills generated/cached data (may contain private info)
.agents/skills/*/data/*.json
.agents/skills/*/data/*.csv
.agents/skills/*/data/*.db
.agents/skills/*/data/*.sqlite
# Explicitly exclude groups data (private WhatsApp group names/JIDs)
.agents/skills/uazapi-groups/**/data/groups.json

# IDE
.vscode/
.idea/
*.swp
*.swo
*~

# OS
.DS_Store
Thumbs.db

# Debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# Python
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
